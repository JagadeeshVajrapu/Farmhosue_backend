# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas — split vars (password with @ is encoded automatically)
MONGODB_USER=your_db_user
MONGODB_PASSWORD=your_password
MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
MONGODB_DATABASE=vidhaan_farmhouse

# Or full connection string from Atlas Connect:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/vidhaan_farmhouse?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email — Gmail SMTP (use App Password, not account password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Vidhaan Farmhouse <your-email@gmail.com>
OWNER_EMAIL=vidhaanfarms@gmail.com
ADMIN_EMAIL=admin@vidhaan.com

# WhatsApp — optional
WHATSAPP_ADMIN_PHONE=919876543210
WHATSAPP_WEBHOOK_URL=

# Twilio WhatsApp — optional (overrides webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
