# Server
PORT=5000
NODE_ENV=production

# MongoDB — OPTIONAL (not needed for contact/enquiry form; email-only mode)
# Omit all MongoDB vars or set MONGODB_ENABLED=false for deployment without a database.
MONGODB_ENABLED=false

# Only required if you use admin dashboard, bookings, or auth with DB:
# MONGODB_USER=your_db_user
# MONGODB_PASSWORD=your_password
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGODB_DATABASE=vidhaan_farmhouse
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/vidhaan_farmhouse?retryWrites=true&w=majority
# MONGODB_REQUIRED=true

# JWT (required even without MongoDB)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary — optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS) — comma-separated origins, no trailing slashes
CLIENT_URL=https://vidhaanfarmhouse.com,http://localhost:3000

# Email — REQUIRED for contact/enquiry form (Gmail App Password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vidhaanfarms@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Vidhaan Farmhouse <vidhaanfarms@gmail.com>
OWNER_EMAIL=vidhaanfarms@gmail.com
ADMIN_EMAIL=vidhaanfarms@gmail.com

# WhatsApp — optional
WHATSAPP_ADMIN_PHONE=918447790095
WHATSAPP_WEBHOOK_URL=

# Twilio WhatsApp — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
